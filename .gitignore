# =========================================================================
# OS / editor noise
# =========================================================================
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml
**/.claude/worktrees/

# =========================================================================
# Node / JavaScript
# =========================================================================
# Dependencies — reproducible via `npm install`.
node_modules/
**/node_modules/

# Build output (Vite). Deployed artifacts live in dev/career/index.html
# and dev/career/assets/ — those are kept tracked deliberately so GitHub
# Pages can serve them.
dev/career/dist/

# =========================================================================
# Portal (/portal) — Cognito + S3 login/upload (see backend/)
# =========================================================================
# Vite scratch. The deployed bundle (portal/index.html + portal/assets/) and the
# Terraform-generated portal/config.js are committed deliberately so GitHub Pages
# can serve them — config.js holds only public client ids, no secrets.
portal/.vite/
portal/src/config.js

# =========================================================================
# Local scratch / never-commit (migration backups, downloaded user files,
# private keys). These hold real uploaded data and must never enter git.
# =========================================================================
**/_migrate_tmp/
backend/_isolation_test.mjs
*.p8

# Logs / debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# =========================================================================
# Environment files
# =========================================================================
# Keep environment files out of git. Even public VITE_* values can reveal
# deploy topology and should live in local/hosting configuration instead.
.env
.env.production
**/.env
**/.env.production
.env.local
.env.*.local
.env.development
.env.development.local

# =========================================================================
# Terraform
# =========================================================================
# Local .terraform directories
.terraform/

# Terraform archive_file scratch output (regenerated on every apply)
.terraform-build/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout
