{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Нормализирани точки за картата на ПТП",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "boundary",
    "fields",
    "dictionaries",
    "summary",
    "events"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "events": {
      "type": "array",
      "minItems": 1000,
      "items": {
        "type": "array",
        "minItems": 9,
        "maxItems": 9
      }
    }
  }
}
