{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Набор от данни — нормализирани метаданни",
  "type": "object",
  "required": [
    "identifier",
    "identifier_type",
    "title",
    "category_id",
    "organisation_id",
    "formats",
    "resource_count",
    "portal_url"
  ],
  "properties": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "identifier_type": {
      "type": "string",
      "enum": [
        "uuid",
        "legacy"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "category_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 14
    },
    "organisation_id": {
      "type": [
        "integer",
        "null"
      ]
    },
    "formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resource_count": {
      "type": "integer",
      "minimum": 0
    },
    "portal_url": {
      "type": "string",
      "format": "uri"
    }
  }
}
