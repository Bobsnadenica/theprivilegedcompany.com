approved_landmark_noncurrent_retention_days = 30
discovery_cache_retention_days     = 30
cognito_admin_group_name     = "admin"
cognito_moderator_group_name = "moderator"
cognito_user_group_name      = "user"
cognito_callback_urls = []
cognito_logout_urls   = []
cors_allowed_origins = ["*"]
