# =========================================================================
# AIPost247 configuration.
# Copy this file to ".env" (or just run `./run.sh setup` / `run.bat setup`) and fill it in.
# The real .env is gitignored and stored with 600 permissions — never commit it.
# =========================================================================

# --- Content generator ---------------------------------------------------
# Login-only (no API key):
#   AI_PROVIDER = "antigravity"  -> sign in with Google (Gemini CLI's successor)  [default]
#   AI_PROVIDER = "gemini"       -> sign in with Google (legacy; Google retiring it)
#   AI_PROVIDER = "codex"        -> "Sign in with ChatGPT" (free tier works)
# API-key based:
#   AI_PROVIDER = "openai"       -> use an OpenAI API key
AI_PROVIDER=antigravity
# Only used when AI_PROVIDER=gemini:
GEMINI_MODEL=gemini-2.5-flash
# Only needed when AI_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Facebook Graph API --------------------------------------------------
# Easiest: run `./run.sh setup` / `run.bat setup`, choose "Log in with Facebook", and these
# get filled in automatically after you pick your Page.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# One-time Meta app credentials (required by Facebook for ANY Page posting):
FB_APP_ID=
FB_APP_SECRET=
GRAPH_API_VERSION=v21.0

# --- Scheduling ----------------------------------------------------------
# SCHEDULE_MODE = "interval" or "daily"
SCHEDULE_MODE=interval
# interval mode: how often to post, in minutes (240 = every 4 hours)
SCHEDULE_INTERVAL_MINUTES=240
# daily mode: comma-separated 24h times in the machine's LOCAL timezone
SCHEDULE_TIMES=09:00,18:00

# --- Behaviour -----------------------------------------------------------
RUN_ON_START=true
DRY_RUN=false
POST_MAX_CHARS=600
POST_LANGUAGE=English

# --- Dashboard -----------------------------------------------------------
# Web dashboard port. If it's busy, the app automatically picks the next free
# one — so you can run several copies (each in its own folder) side by side.
# Set this only if you want to PIN a specific port for this instance.
# AIPOST_DASHBOARD_PORT=8730
