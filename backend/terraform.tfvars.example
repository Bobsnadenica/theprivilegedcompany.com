# Copy to terraform.tfvars and edit if you need to override defaults.
# terraform.tfvars is gitignored (it may carry environment-specific values).

region  = "eu-west-1"
project = "tpc-portal"

# Admin who receives contact-form briefs as portal notifications.
# Required. Keep it here (terraform.tfvars is gitignored) — never in a committed file.
admin_email = "you@example.com"

cors_allowed_origins = [
  "https://www.theprivilegedcompany.com",
  "https://theprivilegedcompany.com",
  "http://localhost:5173",
]
